{
  "name": "@cloaka/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/apps/api/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/apps/api/src/index.js",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "test": "npm run build && node dist/apps/api/src/test-runner.js",
    "typecheck": "npm run prisma:generate && tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@cloaka/shared": "0.1.0",
    "@prisma/client": "^6.6.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.73.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
